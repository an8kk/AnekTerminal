{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "template": " {{ .Path }}",
          "foreground": "#7a7a7a",
          "properties": {
            "style": "full",
            "home_icon": "C:\\Users\\Anek",
            "folder_separator_icon": "\\"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "git",
          "style": "plain",
          "template": "on 󰘬 {{ .HEAD }} ",
          "foreground": "#bb9af7"
        },
        {
          "type": "npm",
          "style": "plain",
          "template": "is 󰏗 {{ .Full }} ",
          "foreground": "#e0af68"
        },
        {
          "type": "node",
          "style": "plain",
          "template": "via  {{ .Full }}",
          "foreground": "#7dcfff",
          "properties": {
            "display_mode": "always",
            "home_enabled": true
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "shell",
          "style": "plain",
          "template": "{{ .Name }} {{ .Version }}",
          "foreground": "#bb9af7"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "❯",
          "foreground": "#d0d0d0"
        }
      ]
    }
  ]
}
