{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "#8A8F98",
          "background": "transparent",
          "template": " {{ .Path }}",
          "properties": {
            "style": "full"
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "overflow": "hidden",
      "segments": [
        {
          "type": "shell",
          "style": "plain",
          "foreground": "#6E7681",
          "background": "transparent",
          "template": "pwsh {{ .Version }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#8A8F98",
          "background": "transparent",
          "template": " |  {{ .HEAD }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#C9D1D9",
          "background": "transparent",
          "template": "❯"
        }
      ]
    }
  ]
}
